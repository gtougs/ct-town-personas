# CT Town Personas — Environment Variables
# Copy this file to .env and fill in your values.
# .env is gitignored — never commit real keys.

# Socrata app token (optional but avoids throttling)
# Register at: https://dev.socrata.com/register
SOCRATA_APP_TOKEN=

# Census Bureau API key (optional, higher rate limits)
# Register at: https://api.census.gov/data/key_signup.html
CENSUS_API_KEY=

# API server
API_HOST=0.0.0.0
API_PORT=8000
